      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": false
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Generated tokens / sec",
      "description": "Output token throughput. Useful for distinguishing request count from actual decode work.",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(vllm:generation_tokens_total[1m]))",
          "legendFormat": "gen tok/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
